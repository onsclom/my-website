{
  "rewrites": [
    {
      "source": "/posts",
      "destination": "https://old.onsclom.net/posts"
    },
    {
      "source": "/posts/:path*",
      "destination": "https://old.onsclom.net/posts/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://old.onsclom.net/images/:path*"
    }
  ]
}
